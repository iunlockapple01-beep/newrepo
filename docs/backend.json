
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "email": {
          "type": "string",
          "description": "The user's email address"
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile picture"
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the user logged in"
        },
        "balance": {
          "type": "number",
          "description": "The user's account balance"
        },
        "ipAddress": {
          "type": "string",
          "description": "The user's registered IP address"
        }
      },
      "required": ["displayName", "email"]
    },
    "submission": {
      "title": "Submission",
      "description": "An IMEI submission for checking",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who made the submission"
        },
        "model": {
          "type": "string",
          "description": "The device model"
        },
        "price": {
          "type": "number",
          "description": "The price for the unlock service"
        },
        "image": {
          "type": "string",
          "description": "URL of the device image"
        },
        "imei": {
          "type": "string",
          "description": "The IMEI or serial number of the device"
        },
        "status": {
          "type": "string",
          "enum": ["waiting", "feedback", "paid", "eligible", "not_supported", "find_my_off", "device_found", "chimaera", "banned"],
          "description": "The current status of the submission"
        },
        "successRate": {
          "type": "number",
          "description": "The probability percentage of a successful unlock"
        },
        "feedback": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ipAddress": {
          "type": "string",
          "description": "The IP address from which the submission was made"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "model", "price", "imei", "status", "createdAt"]
    },
    "banned_ip": {
      "title": "Banned IP",
      "description": "An IP address that is blocked from making new submissions",
      "type": "object",
      "properties": {
        "ip": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["ip", "createdAt"]
    },
    "payment_claim": {
      "title": "Payment Claim",
      "description": "A claim made by a user that they have paid for an unlock",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "submissionId": { "type": "string" },
        "imei": { "type": "string" },
        "model": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "userId", "submissionId", "imei", "model", "price", "status", "createdAt"]
    },
    "order": {
      "title": "Order",
      "description": "A confirmed and paid unlock order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "submissionId": { "type": "string" },
        "imei": { "type": "string" },
        "model": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["confirming_payment", "processing", "approved", "declined", "unlocked", "ready_for_activation_bulk", "ready_for_activation"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "userId", "submissionId", "imei", "model", "price", "status", "createdAt"]
    },
    "ticket": {
      "title": "Support Ticket",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "category": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "subject", "message", "status", "createdAt"]
    },
    "counters": {
      "title": "Counters",
      "type": "object",
      "properties": {
        "registeredUsers": { "type": "number" },
        "unlockedDevices": { "type": "number" }
      },
      "required": ["registeredUsers", "unlockedDevices"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "User profile"
    },
    "/submissions/{submissionId}": {
      "schema": { "$ref": "#/backend/entities/submission" },
      "description": "Device check submissions"
    },
    "/banned_users/{userId}": {
      "schema": { "type": "object", "properties": { "userId": { "type": "string" }, "createdAt": { "type": "string" } } },
      "description": "Banned user IDs"
    },
    "/banned_ips/{ipId}": {
      "schema": { "$ref": "#/backend/entities/banned_ip" },
      "description": "Banned IP addresses"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/order" },
      "description": "Unlock orders"
    },
    "/tickets/{ticketId}": {
      "schema": { "$ref": "#/backend/entities/ticket" },
      "description": "Support tickets"
    },
    "/counters/metrics": {
      "schema": { "$ref": "#/backend/entities/counters" },
      "description": "Site metrics"
    },
    "/payment_claims/{claimId}": {
      "schema": { "$ref": "#/backend/entities/payment_claim" },
      "description": "Payment claims"
    }
  }
}
